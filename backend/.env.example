# ─── OBLIGATOIRE ─────────────────────────────────────────────────────────────
# Clé API Anthropic — obtenir sur https://console.anthropic.com/
# Le free tier offre suffisamment de tokens pour développer et démontrer le projet
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONNEL ────────────────────────────────────────────────────────────────
# Token GitHub — sans token : 60 req/h. Avec token : 5000 req/h
# Créer un token (sans permission spéciale) sur https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL du frontend en production (pour CORS)
# Exemple : https://devsummarizer.vercel.app
FRONTEND_URL=http://localhost:5173

# Port du serveur (Render injecte automatiquement la variable PORT en prod)
PORT=3001
